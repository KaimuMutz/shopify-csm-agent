# --- LLM ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.2

# --- Shopify (per default client; per-client overrides live in DB) ---
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01
SHOPIFY_WEBHOOK_SECRET=

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
SLACK_SIGNING_SECRET=
SLACK_REVIEW_CHANNEL=#csm-review

# --- Storage ---
DATABASE_URL=sqlite:///./data/csm.db
REDIS_URL=redis://localhost:6379/0

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# --- Operating policy ---
DEFAULT_CONFIDENCE_THRESHOLD=0.78
DAILY_TOKEN_BUDGET_USD=5.0
ESCALATE_REFUNDS=true
ESCALATE_ADDRESS_CHANGES=true
